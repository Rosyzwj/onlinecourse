<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.CoursesortDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.CoursesortEntity" id="coursesortMap">
        <result property="coursesort" column="coursesort"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.CoursesortVO" >
		SELECT * FROM coursesort  coursesort
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.CoursesortVO" >
		SELECT  coursesort.* FROM coursesort  coursesort
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.CoursesortView" >

		SELECT  coursesort.* FROM coursesort  coursesort
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.CoursesortView" >
		SELECT * FROM coursesort  coursesort <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

</mapper>
