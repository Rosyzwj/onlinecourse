<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ResourceDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.ResourceEntity" id="resourceMap">

        <result property="resourcenumber" column="resourcenumber"/>
        <result property="resourcename" column="resourcename"/>
        <result property="resourcesort" column="resourcesort"/>
        <result property="cover" column="cover"/>

        <result property="resourceintroduction" column="resourceintroduction"/>
        <result property="resourcedetail" column="resourcedetail"/>
        <result property="teacheraccount" column="teacheraccount"/>
        <result property="teachername" column="teachername"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.ResourceVO" >
		SELECT * FROM resource  resource
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.ResourceVO" >
		SELECT  resource.* FROM resource  resource
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.ResourceView" >

		SELECT  resource.* FROM resource  resource
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.ResourceView" >
		SELECT * FROM resource  resource <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

</mapper>
